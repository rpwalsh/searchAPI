APP_ENV=production
SITE_ID=customer-sea-01
API_ADDR=:8080
API_KEY=replace-with-site-secret

DATABASE_URL=postgres://searchapi:replace-me@postgres.internal:5432/telemetry?sslmode=disable

# Optional. Leave empty for air-gapped/Postgres-only search.
ELASTICSEARCH_URL=
ELASTICSEARCH_API_KEY=
ELASTICSEARCH_INDEX=hardware-telemetry-events-customer-sea-01

INGEST_MAX_BYTES=16777216
SHUTDOWN_TIMEOUT_SECONDS=20
SEED_ON_START=false
