APP_ENV=demo
SITE_ID=demo-seattle-lab
API_ADDR=:8080
API_KEY=demo-key

DATABASE_URL=postgres://postgres:postgres@localhost:5432/telemetry?sslmode=disable

# Demo mode seeds the mock hardware telemetry workspace on startup.
SEED_ON_START=true

# Optional. Leave empty to use PostgreSQL fallback search.
ELASTICSEARCH_URL=
ELASTICSEARCH_API_KEY=
ELASTICSEARCH_INDEX=hardware-telemetry-events-demo
